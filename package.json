{
  "name": "lightning-pos-service-center",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:portal": "turbo run dev --filter=portal*",
    "dev:sync": "turbo run dev --filter=pos-sync*",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "clean-install": "find -E . -mindepth 1 -maxdepth 3 -type d -regex '.*(node_modules|dist|.turbo|.serverless|.next|.out)$' -exec rm -rf {} + && pnpm install"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
